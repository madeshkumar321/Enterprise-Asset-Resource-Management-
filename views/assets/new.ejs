<%- include('../partials/header') %>

<h1>Register Asset</h1>

<form method="POST" action="/assets" class="stacked-form">
  <label>Name</label>
  <input type="text" name="name" required>

  <label>Category</label>
  <select name="category_id">
    <option value="">Uncategorized</option>
    <% categories.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) %>
  </select>

  <label>Serial Number</label>
  <input type="text" name="serial_number">

  <label>Acquisition Date</label>
  <input type="date" name="acquisition_date">

  <label>Acquisition Cost</label>
  <input type="number" step="0.01" name="acquisition_cost">

  <label>Condition</label>
  <select name="condition">
    <option>Excellent</option><option>Good</option><option>Fair</option><option>Poor</option>
  </select>

  <label>Location</label>
  <input type="text" name="location">

  <label><input type="checkbox" name="is_bookable"> Shared / bookable resource</label>

  <button type="submit">Register Asset</button>
</form>

<%- include('../partials/footer') %>
